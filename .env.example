PORT=4000
HOST=0.0.0.0
# Your Mac's LAN IP — used in startup logs; update if your IP changes
LAN_HOST=192.168.100.156
NODE_ENV=development

# JWT secret — required in production (Vercel / Netlify env vars)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins (Expo web + local + hosted frontend)
# Production — paste into Vercel backend env var CORS_ORIGINS (optional extras).
# *.vercel.app frontend URLs are allowed automatically.
# CORS_ORIGINS=http://localhost:8081,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://192.168.100.156:8081

# Odoo
ODOO_URL=
ODOO_DB=
ODOO_API_KEY=

# Optional: extra res.partner (contact) fields to fetch, comma-separated
# technical names. Example: x_studio_loyalty_id,x_studio_region
ODOO_CONTACT_EXTRA_FIELDS=

# Custom Township model technical name (Studio). Used to resolve city/state/zip/country.
ODOO_TOWNSHIP_MODEL=x_townships
